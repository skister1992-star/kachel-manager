<dyad-write path="server/routes/api/auth.get.ts" description="Authentication endpoint for checking credentials">
import { defineHandler } from "nitro";
import fs from "node:fs";

export default defineHandler(async (event) => {
  const body = await readBody<{ username?: string; password?: string }>(event);
  
  if (!body?.username || !body?.password) {
    return { authenticated: false, error: "Username and password required" };
  }
  
  // In a real implementation this would check against config file
  const { username, password } = body;
  
  // Mock authentication - in reality, we'd verify against stored credentials
  if (username === "admin" && password === "password") {
    return { authenticated: true, username };
  }
  
  return { authenticated: false, error: "Invalid credentials" };
});